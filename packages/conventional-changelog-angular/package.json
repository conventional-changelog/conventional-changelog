{
  "name": "conventional-changelog-angular",
  "type": "module",
  "version": "9.2.1",
  "description": "Angular preset for conventional-changelog.",
  "author": "Steve Mao",
  "license": "ISC",
  "homepage": "https://conventional-changelog.js.org/presets/angular/",
  "repository": {
    "type": "git",
    "url": "https://github.com/conventional-changelog/conventional-changelog.git",
    "directory": "packages/conventional-changelog-angular"
  },
  "bugs": {
    "url": "https://github.com/conventional-changelog/conventional-changelog/issues"
  },
  "keywords": [
    "conventional-changelog",
    "angular",
    "preset"
  ],
  "engines": {
    "node": ">=22"
  },
  "exports": {
    "types": "./src/index.d.ts",
    "import": "./src/index.js"
  },
  "publishConfig": {
    "directory": "package",
    "linkDirectory": false
  },
  "files": [
    "src"
  ],
  "scripts": {
    "clear": "del ./package",
    "prepublishOnly": "run clear clean-publish",
    "postpublish": "pnpm clear"
  },
  "dependencies": {
    "@conventional-changelog/template": "workspace:^"
  }
}
